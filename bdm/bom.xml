<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<businessObjectModel xmlns="http://documentation.bonitasoft.com/bdm-xml-schema/1.0" modelVersion="1.0">
    <businessObjects>
        <businessObject qualifiedName="com.company.model.Incidencia">
            <fields>
                <field type="STRING" length="255" name="idTicketOdoo" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="clienteNombre" nullable="false" collection="false"/>
                <field type="STRING" length="255" name="pisoActual" nullable="false" collection="false"/>
                <field type="STRING" length="255" name="motivoQueja" nullable="false" collection="false"/>
                <field type="STRING" length="255" name="estado" nullable="false" collection="false"/>
                <field type="STRING" length="255" name="decisionFinal" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="pisoNuevoId" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="correo" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="telefono" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.company.model.Reserva" fetchType="LAZY" name="reserva" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.company.model.Piso" fetchType="LAZY" name="pisoRelacionado" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.company.model.UserCliente" fetchType="LAZY" name="clienteRelacionado" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries/>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.company.model.Piso">
            <fields>
                <field type="STRING" length="255" name="nombre" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="direccion" nullable="true" collection="false"/>
                <field type="DOUBLE" length="255" name="precioDia" nullable="true" collection="false"/>
                <field type="INTEGER" length="255" name="capacidad" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="estado" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries/>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.company.model.Reserva">
            <fields>
                <relationField type="AGGREGATION" reference="com.company.model.Piso" fetchType="LAZY" name="piso" nullable="true" collection="false"/>
                <relationField type="AGGREGATION" reference="com.company.model.UserCliente" fetchType="LAZY" name="persona" nullable="true" collection="false"/>
                <field type="OFFSETDATETIME" length="255" name="fechaEntrada" nullable="true" collection="false"/>
                <field type="OFFSETDATETIME" length="255" name="fechaSalida" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="estado" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries>
                <query name="buscaSolapamiento" content="SELECT r FROM Reserva r&#13;&#10;&#13;&#10;WHERE r.piso = :pisoBuscado AND r.fechaEntrada &lt;= :fechaFinBuscada AND r.fechaSalida &gt;= :fechaInicioBuscada " returnType="com.company.model.Reserva">
                    <queryParameters>
                        <queryParameter name="fechaEntrada" className="java.time.OffsetDateTime"/>
                        <queryParameter name="fechaSalida" className="java.time.OffsetDateTime"/>
                        <queryParameter name="estado" className="java.lang.String"/>
                    </queryParameters>
                </query>
            </queries>
            <indexes/>
        </businessObject>
        <businessObject qualifiedName="com.company.model.UserCliente">
            <fields>
                <field type="STRING" length="255" name="nombre" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="password" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="dni" nullable="true" collection="false"/>
                <field type="LOCALDATE" length="255" name="fechaNacimiento" nullable="true" collection="false"/>
                <field type="STRING" length="255" name="correoElectronico" nullable="true" collection="false"/>
            </fields>
            <uniqueConstraints/>
            <queries/>
            <indexes/>
        </businessObject>
    </businessObjects>
</businessObjectModel>
