    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "var pisoSeleccionado = $data.formInput.nuevoPisoInput;\r",
        "var idFinal = pisoSeleccionado;\r",
        "\r",
        "// Si el formulario ha guardado un objeto entero, extraemos SOLO el número\r",
        "if (pisoSeleccionado && pisoSeleccionado.persistenceId) {\r",
        "    idFinal = pisoSeleccionado.persistenceId;\r",
        "}\r",
        "\r",
        "return {\r",
        "    'nuevoPisoInput': idFinal\r",
        "};"
      ],
      "exposed" : false
    },
    "context" : {
