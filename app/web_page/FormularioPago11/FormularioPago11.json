    "listaMeses" : {
      "type" : "json",
      "value" : [
        "[\"01\", \"02\", \"03\", \"04\", \"05\", \"06\", \"07\", \"08\", \"09\", \"10\", \"11\", \"12\"]"
      ],
      "exposed" : false
    },
    "posiblesAnyos" : {
      "type" : "expression",
      "value" : [
        "var currentYear = new Date().getFullYear();",
        "var years = [];",
        "for (var i = 0; i < 11; i++) {",
        "    years.push((currentYear + i).toString());",
        "}",
        "return years;"
      ],
      "exposed" : false
    },
    "esTarjetaCaducada" : {
      "type" : "expression",
      "value" : [
        "var today = new Date();",
        "var currentMonth = today.getMonth() + 1;",
        "var currentYear = today.getFullYear();",
        "",
        "var selMonth = parseInt($data.formInput.expiracionMes);",
        "var selYear = parseInt($data.formInput.expiracionAnio);",
        "",
        "if (selYear === currentYear && selMonth < currentMonth) {",
        "    return true;",
        "}",
        "return false;"
      ],
      "exposed" : false
    }
