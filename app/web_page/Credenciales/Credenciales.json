  "variables" : {
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "formInput" : {
      "type" : "json",
      "value" : [
        "{\r",
        "  \"nombre\" : \"\",\r",
        "  \"fechaNacimiento\" : null,\r",
        "  \"dni\" : \"\",\r",
        "  \"correoElectronico\" : \"\"\r",
        "}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "return {",
        "\tnombre: $data.formInput.nombre,",
        "\tfechaNacimiento: $data.formInput.fechaNacimiento,",
        "\tdni: $data.formInput.dni,",
        "\tcorreoElectronico: $data.formInput.correoElectronico",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    },
    "formularioValido" : {
      "type" : "expression",
      "value" : [
        "// 1. Comprobar DNI (8 números y 1 letra final)\r",
        "var dni = $data.formInput.dni;\r",
        "var dniValido = false;\r",
        "if (dni) {\r",
        "    dniValido = /^\\d{8}[A-Za-z]$/.test(dni);\r",
        "}\r",
        "\r",
        "// 2. Comprobar Correo (Debe contener una arroba '@')\r",
        "var correo = $data.formInput.correoElectronico;\r",
        "var correoValido = false;\r",
        "if (correo) {\r",
        "    correoValido = correo.includes('@');\r",
        "}\r",
        "\r",
        "// 3. Comprobar Fecha de Nacimiento (Debe ser anterior a 2008)\r",
        "var fecha = $data.formInput.fechaNacimiento;\r",
        "var fechaValida = false;\r",
        "if (fecha) {\r",
        "    var anioUsuario = new Date(fecha).getFullYear();\r",
        "    fechaValida = (anioUsuario < 2008);\r",
        "}\r",
        "\r",
        "// RESULTADO FINAL: Devuelve 'true' SOLO si todo está perfecto\r",
        "return dniValido && correoValido && fechaValida;"
      ],
      "exposed" : false
    }
  },
