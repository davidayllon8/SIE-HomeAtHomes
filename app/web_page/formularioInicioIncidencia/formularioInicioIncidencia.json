    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "var datosLimpios = angular.copy($data.formInput.incidenciaInput);\r",
        "\r",
        "// 1. Extraemos el Piso\r",
        "if (datosLimpios.idPiso && datosLimpios.idPiso.persistenceId) {\r",
        "    datosLimpios.pisoId = datosLimpios.idPiso.persistenceId;\r",
        "}\r",
        "\r",
        "// 2. Forzamos los números (Long) para el piso y la reserva\r",
        "if (datosLimpios.pisoId) {\r",
        "    datosLimpios.pisoId = parseInt(datosLimpios.pisoId, 10);\r",
        "} else {\r",
        "    datosLimpios.pisoId = null;\r",
        "}\r",
        "\r",
        "if (datosLimpios.idReservaInput) {\r",
        "    datosLimpios.idReservaInput = parseInt(datosLimpios.idReservaInput, 10);\r",
        "} else {\r",
        "    datosLimpios.idReservaInput = null;\r",
        "}\r",
        "\r",
        "// 3. Borramos la variable temporal del piso\r",
        "delete datosLimpios.idPiso;\r",
        "\r",
        "return {\r",
        "  \"incidenciaInput\": datosLimpios\r",
        "};"
      ],
      "exposed" : false
    },
