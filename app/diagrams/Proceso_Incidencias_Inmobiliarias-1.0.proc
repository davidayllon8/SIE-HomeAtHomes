        <defaultValue xmi:type="expression:Expression" xmi:id="_gfEy4UOsEfGJ3usuMHBVgw" name="init_incidencia()" content="def incidenciaVar = new com.company.model.Incidencia()&#xD;&#xA;&#xD;&#xA;// 1. Buscamos la Reserva Maestra&#xD;&#xA;if (incidenciaInput.idReservaInput != null) {&#xD;&#xA;    def reservaEncontrada = reservaDAO.findByPersistenceId(incidenciaInput.idReservaInput)&#xD;&#xA;    &#xD;&#xA;    if (reservaEncontrada != null) {&#xD;&#xA;        // 2. Vinculamos la reserva a la incidencia&#xD;&#xA;        incidenciaVar.reserva = reservaEncontrada&#xD;&#xA;        &#xD;&#xA;        // 3. Extraemos los datos obligatorios para que Hibernate no se queje&#xD;&#xA;        incidenciaVar.clienteNombre = reservaEncontrada.persona.nombre&#xD;&#xA;        incidenciaVar.pisoActual = reservaEncontrada.piso.nombre&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// 4. Datos básicos&#xD;&#xA;incidenciaVar.motivoQueja = incidenciaInput.motivo&#xD;&#xA;incidenciaVar.estado = &quot;Abierta&quot;&#xD;&#xA;&#xD;&#xA;return incidenciaVar" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.company.model.Incidencia">
