              <parameters xmi:type="connectorconfiguration:ConnectorParameter" xmi:id="_82_X10O5EfGJ3usuMHBVgw" key="body">
                <expression xmi:type="expression:Expression" xmi:id="_82_X2EO5EfGJ3usuMHBVgw" name="body()" content="import groovy.json.JsonBuilder&#xD;&#xA;import java.time.LocalDate&#xD;&#xA;import java.time.temporal.ChronoUnit&#xD;&#xA;&#xD;&#xA;double totalDevolucion = 0.0&#xD;&#xA;def diagnostico = &quot;OK&quot;&#xD;&#xA;&#xD;&#xA;try {&#xD;&#xA;&#x9;if (incidencia.reserva != null &amp;&amp; incidencia.reserva.piso != null) {&#xD;&#xA;&#x9;&#x9;// 1. Extraemos el precio del piso (Si es null, ponemos 0 para que no explote)&#xD;&#xA;&#x9;&#x9;def precioNoche = incidencia.reserva.piso.precioDia != null ? incidencia.reserva.piso.precioDia : 0.0&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;// 2. Extraemos las fechas como texto bruto&#xD;&#xA;&#x9;&#x9;def fechaInStr = incidencia.reserva.fechaEntrada.toString()&#xD;&#xA;&#x9;&#x9;def fechaOutStr = incidencia.reserva.fechaSalida.toString()&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;// 3. Recortamos SOLO la parte de la fecha (YYYY-MM-DD) para evitar problemas de TimeZone&#xD;&#xA;&#x9;&#x9;LocalDate inicio = LocalDate.parse(fechaInStr.substring(0, 10))&#xD;&#xA;&#x9;&#x9;LocalDate fin = LocalDate.parse(fechaOutStr.substring(0, 10))&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;// 4. Calculamos los días matemáticamente&#xD;&#xA;&#x9;&#x9;long noches = ChronoUnit.DAYS.between(inicio, fin)&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;// 5. Anti-errores: Si por algún motivo da negativo o 0, cobramos 1 noche mínima&#xD;&#xA;&#x9;&#x9;if (noches &lt;= 0) { noches = 1 }&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;totalDevolucion = noches * precioNoche&#xD;&#xA;&#x9;} else {&#xD;&#xA;&#x9;&#x9;diagnostico = &quot;Datos de reserva o piso nulos&quot;&#xD;&#xA;&#x9;}&#xD;&#xA;} catch (Exception e) {&#xD;&#xA;&#x9;diagnostico = &quot;Error interno: &quot; + e.getMessage()&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Opcional: He dejado la variable 'diagnostico' en el texto. Si sale 0.0, Odoo nos chivará por qué falló.&#xD;&#xA;def textoFinal = &quot;RESOLUCIÓN FINAL:\nEl cliente abandona el alojamiento.\n===================================\n💰 TOTAL A DEVOLVER: &quot; + totalDevolucion + &quot; €\n===================================\n(Diagnóstico: &quot; + diagnostico + &quot;)&quot;&#xD;&#xA;&#xD;&#xA;def builder = new JsonBuilder()&#xD;&#xA;builder {&#xD;&#xA;&#x9;ticket_odoo_id incidencia.idTicketOdoo != null ? incidencia.idTicketOdoo : &quot;&quot;&#xD;&#xA;&#x9;tipo_resolucion &quot;DEVOLUCIÓN&quot;&#xD;&#xA;&#x9;cliente_nombre incidencia.clienteNombre != null ? incidencia.clienteNombre : &quot;Cliente&quot;&#xD;&#xA;&#x9;resolucion_texto textoFinal&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;return builder.toString()" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnTypeFixed="true">
