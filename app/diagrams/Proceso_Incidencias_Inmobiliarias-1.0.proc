              <rightOperand xmi:type="expression:Expression" xmi:id="_buKYCkOjEfGJ3usuMHBVgw" name="newScript()" content="import groovy.json.JsonSlurper&#xD;&#xA;&#xD;&#xA;// Utilizamos la variable correcta de Bonita: status_code (con guion bajo)&#xD;&#xA;if (status_code >= 200 &amp;&amp; status_code &lt; 300) {&#xD;&#xA;&#x9;// Parseamos el JSON devuelto por n8n&#xD;&#xA;&#x9;def jsonResponse = new JsonSlurper().parseText(bodyAsString)&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// Retornamos SOLO el ID como texto. Bonita lo inyectará usando el método setIdTicketOdoo&#xD;&#xA;&#x9;return jsonResponse.ticketId.toString()&#xD;&#xA;} else {&#xD;&#xA;&#x9;// Si n8n falla, lanzamos excepción para detener la tarea y activar la ruta de error&#xD;&#xA;&#x9;throw new Exception(&quot;Error en la integración n8n/Odoo. Status: &quot; + status_code + &quot; Body: &quot; + bodyAsString)&#xD;&#xA;}" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT">
                <referencedElements xmi:type="definition:Output" xmi:id="_Dv1yAEPSEfGdypp2W3E4OQ" name="status_code" type="java.lang.Integer"/>
                <referencedElements xmi:type="definition:Output" xmi:id="_Dv1yAUPSEfGdypp2W3E4OQ" name="bodyAsString" type="java.lang.String"/>
              </rightOperand>
              <operator xmi:type="expression:Operator" xmi:id="_buKYDEOjEfGJ3usuMHBVgw" type="JAVA_METHOD" expression="setIdTicketOdoo">
