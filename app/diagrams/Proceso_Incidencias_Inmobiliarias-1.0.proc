            <rightOperand xmi:type="expression:Expression" xmi:id="_hZJ0okSgEfGOIJUXqEtkXA" name="newScript()" content="if (incidencia.reserva != null) {&#xD;&#xA;&#x9;def reservaVieja = incidencia.reserva&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// 1. Clonamos el &quot;ADN&quot; de la reserva&#xD;&#xA;&#x9;def cliente = reservaVieja.persona&#xD;&#xA;&#x9;def fechaIn = reservaVieja.fechaEntrada&#xD;&#xA;&#x9;def fechaOut = reservaVieja.fechaSalida&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// 2. Ponemos el piso anterior en restauración (Garantizado)&#xD;&#xA;&#x9;if (reservaVieja.piso != null) {&#xD;&#xA;&#x9;&#x9;reservaVieja.piso.estado = &quot;En Restauracion&quot;&#xD;&#xA;&#x9;}&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// 3. BÚSQUEDA DEL PISO NUEVO (Convertimos a Long a la fuerza)&#xD;&#xA;&#x9;def pisoNuevo = null&#xD;&#xA;&#x9;if (incidencia.pisoNuevoId != null) {&#xD;&#xA;&#x9;&#x9;try {&#xD;&#xA;&#x9;&#x9;&#x9;Long idSeguro = Long.valueOf(incidencia.pisoNuevoId.toString().trim())&#xD;&#xA;&#x9;&#x9;&#x9;pisoNuevo = pisoDAO.findByPersistenceId(idSeguro)&#xD;&#xA;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;if (pisoNuevo != null) {&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;pisoNuevo.estado = &quot;Ocupado&quot;&#xD;&#xA;&#x9;&#x9;&#x9;}&#xD;&#xA;&#x9;&#x9;} catch (Exception e) {&#xD;&#xA;&#x9;&#x9;&#x9;// Si el ID viene corrupto, no rompemos el proceso&#xD;&#xA;&#x9;&#x9;}&#xD;&#xA;&#x9;}&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// 4. Desvinculamos la reserva de la incidencia y cambiamos su estado a Cancelada&#xD;&#xA;&#x9;incidencia.reserva = null&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;if (reservaVieja != null) {&#xD;&#xA;&#x9;&#x9;// Simplemente cambiamos el atributo.&#xD;&#xA;&#x9;&#x9;// Bonita/Hibernate detectará el cambio y lo guardará automáticamente al terminar la tarea.&#xD;&#xA;&#x9;&#x9;reservaVieja.estado = &quot;Cancelada por Reubicación&quot;&#xD;&#xA;&#x9;}&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// 5. NACIMIENTO DE LA NUEVA RESERVA&#xD;&#xA;&#x9;def nuevaReserva = new com.company.model.Reserva()&#xD;&#xA;&#x9;nuevaReserva.persona = cliente&#xD;&#xA;&#x9;nuevaReserva.piso = pisoNuevo&#xD;&#xA;&#x9;nuevaReserva.fechaEntrada = fechaIn&#xD;&#xA;&#x9;nuevaReserva.fechaSalida = fechaOut&#xD;&#xA;&#x9;nuevaReserva.estado = &quot;Reubicada&quot;&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;// 6. Vinculamos&#xD;&#xA;&#x9;incidencia.reserva = nuevaReserva&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;return incidencia" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.company.model.Incidencia">
